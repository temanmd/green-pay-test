#!/bin/bash
set -e

# Убираем возможный «протухший» server.pid от предыдущего запуска контейнера.
rm -f /app/tmp/pids/server.pid

# Готовим БД на старте только для веб-сервера, чтобы весь стек поднимался одной
# командой `make up`. db:prepare идемпотентен: создаёт БД и накатывает схему/миграции,
# при повторном запуске ничего лишнего не делает.
if [ "${1}" = "bin/rails" ] && [ "${2}" = "server" ]; then
  bin/rails db:prepare
fi

exec "$@"
